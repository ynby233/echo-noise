# Echo-Noise runtime environment template
#
# To use this with GUI-managed Docker containers, copy this file to runtime.env
# in the same /app/config volume and uncomment/edit only the variables you need.
# Lines are parsed by /bin/sh, so keep values as KEY=value or KEY="value".

# TZ=Asia/Shanghai
# ACCESS_LOG=false
# SESSION_SECRET=replace-with-at-least-32-random-characters

# SQLite defaults for persistent Docker deployments.
# DB_TYPE=sqlite
# DB_PATH=/app/data/noise.db

# MCP HTTP/SSE endpoint. Set NOTE_HTTP_PORT=0 to disable the HTTP listener.
# NOTE_HOST=http://localhost:1314
# NOTE_HTTP_PORT=1315
