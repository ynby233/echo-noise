# 忽略不必要的文件
.git
.gitignore
README.md
LICENSE
Dockerfile*
# 注意：Dockerfile 需要 docker-compose.yml 文件，因此不排除此文件
# docker-compose*
.dockerignore

# 忽略开发环境文件
.env
.env.local
.env.*
*.log
logs/

# 忽略本地 Android keystore 目录
.private-android-keystore/

# 忽略构建缓存和临时文件
node_modules/
.nuxt/
.output/
.cache/
dist/
build/

# 忽略桌面端与移动端工程（不参与镜像构建）
desktop/
mobile/

# 忽略测试文件
test/
tests/
*.test.js
*.spec.js

# 忽略IDE文件
.vscode/
.idea/
desktop/tauri/src-tauri/target/
desktop/tauri/dist/
desktop/tauri/src-tauri/gen/
desktop/tauri/src-tauri/public/
mobile/android/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/.idea/
*.swp
*.swo

# 忽略系统文件
.DS_Store
Thumbs.db

# 注意：前端构建需要 web/ 目录，因此不排除此目录
# web/
